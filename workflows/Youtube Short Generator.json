      "id": "65c4b741-688f-4edb-b9f0-6be1573aac1f",
      "name": "Script Voice Generator"
    },
    {
      "parameters": {
        "jsCode": "const allResults = [];\nconst targetInterval = 6;\n\nfor (const item of $input.all()) {\n    const alignmentData = item.json;\n    const chars = alignmentData.alignment.characters;\n    const endTimes = alignmentData.alignment.character_end_times_seconds;\n    \n    let segmentId = 1;\n    let startIndex = 0;\n    let segmentStartTime = 0;\n\n    for (let i = 0; i < chars.length; i++) {\n        const charEndTime = endTimes[i];\n        const isLastChar = (i === chars.length - 1);\n\n        // Si hemos superado los 6 segundos Y el carácter actual es un espacio (fin de palabra)\n        // O si es el final absoluto del texto\n        if ((charEndTime >= segmentStartTime + targetInterval && chars[i] === \" \") || isLastChar) {\n            \n            const segmentText = chars.slice(startIndex, i + 1).join(\"\").trim();\n            \n            allResults.push({\n                json: {\n                    id: segmentId++,\n                    text: segmentText,\n                    duration: Number((charEndTime - segmentStartTime).toFixed(2)),\n                    start_time: Number(segmentStartTime.toFixed(2)),\n                    end_time: Number(charEndTime.toFixed(2))\n                }\n            });\n\n            // El siguiente bloque empieza justo después de este\n            startIndex = i + 1;\n            segmentStartTime = charEndTime;\n        }\n    }\n}\n\nreturn allResults;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        -64
      ],
      "id": "94c41690-445d-40b7-8b2e-6339a02270fa",
