    {
      "parameters": {
        "jsCode": "// Listas de variantes para la randomización\nconst shots = [\n  \"a close-up cinematic shot (focus on head and shoulders)\",\n  \"a front-facing medium shot (showing the robot and the desk)\",\n  \"a wide-angle cinematic shot (showing the full news studio and environment)\"\n];\n\nconst accentColors = [\n  { name: \"electric blue\", hex: \"cyan\" },\n  { name: \"emergency orange\", hex: \"amber\" },\n  { name: \"deep violet\", hex: \"purple\" },\n  { name: \"minimalist silver\", hex: \"white\" },\n  { name: \"forest green\", hex: \"emerald\" }\n];\n\nconst studioMoods = [\n  \"bright, clean and sterile\",\n  \"dimly lit with high-contrast shadows\",\n  \"dynamic with flickering data streams\",\n  \"calm and professional\"\n];\n\n// Función para obtener elemento aleatorio\nconst getRandom = (arr) => arr[Math.floor(Math.random() * arr.length)];\n\nconst selectedShot = getRandom(shots);\nconst selectedColor = getRandom(accentColors);\nconst selectedMood = getRandom(studioMoods);\n\n// Construcción del prompt final\nconst finalPrompt = `A hyper-realistic, ${selectedShot} of a sophisticated humanoid robot news anchor, inspired by the sleek white aesthetic of \"I, Robot.\" The robot has a polished white composite finish and its optical sensors glow with a ${selectedColor.name} light. It is seated in a high-tech TV studio with a ${selectedMood} atmosphere. The image features professional broadcast lower-third banners and the typical top banner and UI elements glowing in ${selectedColor.name} tones. In the background, large screens display blurred digital data in ${selectedColor.name} and silver. 8k resolution, cinematic broadcast quality, photorealistic, anamorphic lens, no readable text.`;\n\nreturn {\n  prompt: finalPrompt,\n  metadata: {\n    shot: selectedShot,\n    color: selectedColor.name,\n    mood: selectedMood\n  }\n};"
      },
