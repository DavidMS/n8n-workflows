      "parameters": {
        "jsCode": "// Este código agrupa todos los ítems de entrada en un solo campo llamado 'noticias'\nconst items = $input.all();\n\n// Formateamos cada objeto en un string legible para el modelo\nconst noticiasFormateadas = items.map(item => {\n  const data = item.json;\n  return `RESUMEN: ${data.linkedin_post} | LINK: ${data.link}`;\n}).join('\\n---\\n'); // Separamos cada noticia con una línea\n\n// Devolvemos un único objeto que contiene el string final\nreturn {\n  noticias: noticiasFormateadas\n};"
